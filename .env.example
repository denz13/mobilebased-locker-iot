# Copy to `.env` for local dev. Values: Firebase Console → Project settings → Your apps → Web app.
# EAS / release APK: `.env` is NOT uploaded. Add the same EXPO_PUBLIC_* keys in:
#   https://expo.dev → your account → this project → Environment variables
# Then run a new `eas build`. Use the same names below (EXPO_PUBLIC_*).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
