{
  "expo": {
    "name": "mobilebased-locker-iot",
    "slug": "mobilebased-locker-iot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "mobilebasedlockeriot",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.mobilebased.lockeriot",
      "icon": "./assets/images/logo.png"
    },
    "android": {
      "package": "com.mobilebased.lockeriot",
      "adaptiveIcon": {
        "backgroundColor": "#134E4A",
        "foregroundImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo.png",
          "resizeMode": "contain",
          "imageWidth": 200,
          "android": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/logo.png",
            "resizeMode": "contain",
            "imageWidth": 200
          },
          "ios": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/logo.png",
            "resizeMode": "contain",
            "imageWidth": 200
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
